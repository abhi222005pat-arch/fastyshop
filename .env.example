# ─────────────────────────────────────────
#  Fasty Shop — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=5000

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=fasty_shop

# JWT Secret (change this to a long random string in production)
JWT_SECRET=fastyshop_super_secret_jwt_key_2025
JWT_EXPIRES_IN=7d

# Admin default credentials (used in DB seed)
ADMIN_EMAIL=admin@fastyshop.com
ADMIN_PASSWORD=Admin@123
